# ==========================================
# Server (Node.js signaling + mediasoup) environment
# Copy to server/.env and fill in real values. Never commit server/.env.
# ==========================================

# MongoDB connection string (used by better-auth + mongoose).
# Local:  mongodb://127.0.0.1:27017/videocall-mediasoup
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?appName=<app>
MONGODB_URI=mongodb://127.0.0.1:27017/videocall-mediasoup

# HTTP / signaling server port
PORT=4000

# Allowed client origin (CORS + better-auth trustedOrigins)
CLIENT_ORIGIN=http://localhost:3000

# Public base URL of this auth/signaling server
BETTER_AUTH_URL=http://localhost:4000

# Secret used to sign/encrypt sessions. Generate one with:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=replace_with_a_long_random_string

# mediasoup announced IP — set to the server's public IP in production
# so remote peers can reach the WebRTC transports. Use 127.0.0.1 for local dev.
MEDIASOUP_ANNOUNCED_IP=127.0.0.1
