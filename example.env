# ==========================================
# Video Conferencing Platform Environment Variables
# ==========================================

# -----------------
# Client-side (Next.js)
# Place these in client/.env.local or client/.env
# -----------------
NEXT_PUBLIC_SERVER_URL=http://localhost:4000

# -----------------
# Server-side (Node.js)
# Place these in server/.env
# -----------------
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# Mediasoup Configuration
# Set to your server's public IP in production for WebRTC to connect
MEDIASOUP_ANNOUNCED_IP=127.0.0.1

# Database
# URI for MongoDB connection (for rooms, users, session state)
MONGODB_URI=mongodb://localhost:27017/video_conferencing

# Authentication
# Secret used to encrypt/decrypt session cookies and tokens
# You can generate one via: openssl rand -base64 32
BETTER_AUTH_SECRET=your_super_secret_string_here
